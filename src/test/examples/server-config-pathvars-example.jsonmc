/*
 * FreeMarker path variable and template example.
 * Demonstrates dynamic response generation using request data.
 *
 * Available template variables:
 * - ${pathVariables.xxx} - URL path parameters
 * - ${headers['Header-Name']!'default'} - Request headers with defaults
 * - ${body.field} - JSON body field access
 * - ${.now?iso_utc} - Current timestamp
 *
 * Test with:
 *   curl http://localhost:9001/users/123
 *   curl -H "X-User-Name: John" http://localhost:9001/users/456/posts/789
 *   curl -X POST -H "Content-Type: application/json" \
 *        -d '{"title":"My Task"}' http://localhost:9001/tasks
 */
[
  {
    "server": {
      "serverId": "pathvars-demo",
      "port": 9001,
      "description": "Demo server for FreeMarker templates"
    },
    "expectations": [
      /* Simple path variable: single ID extraction */
      {
        "httpRequest": {
          "method": "GET",
          "path": "/users/{id}",
          "pathParameters": {
            "id": "[a-zA-Z0-9\\-]+"
          }
        },
        "httpResponse": {
          "statusCode": 200,
          "headers": [{"name": "Content-Type", "values": ["application/json"]}],
          "body": `{
            "userId": "${pathVariables.id}",
            "message": "User details retrieved",
            "requestedBy": "${headers['X-User-Name']!'anonymous'}"
          }`
        }
      },

      /* Multiple path variables with headers */
      {
        "httpRequest": {
          "method": "GET",
          "path": "/users/{userId}/posts/{postId}",
          "pathParameters": {
            "userId": "[a-zA-Z0-9\\-]+",
            "postId": "[a-zA-Z0-9\\-]+"
          }
        },
        "httpResponse": {
          "statusCode": 200,
          "headers": [{"name": "Content-Type", "values": ["application/json"]}],
          "body": `{
            "userId": "${pathVariables.userId}",
            "postId": "${pathVariables.postId}",
            "title": "Post ${pathVariables.postId} by user ${pathVariables.userId}",
            "timestamp": "${.now?iso_utc}"
          }`
        }
      },

      /* POST with body field access and defaults */
      {
        "httpRequest": {
          "method": "POST",
          "path": "/tasks"
        },
        "httpResponse": {
          "statusCode": 201,
          "headers": [{"name": "Content-Type", "values": ["application/json"]}],
          "body": `{
            "id": "task-new-123",
            "title": "${body.title}",
            "description": "${body.description!'No description provided'}",
            "priority": "${body.priority!'medium'}",
            "createdAt": "${.now?iso_utc}"
          }`
        }
      }
    ]
  }
]
