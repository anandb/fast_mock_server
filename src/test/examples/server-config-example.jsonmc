/*
 * HTTP + HTTPS multi-server example.
 * Test: curl http://localhost:9001/api/users
 *       curl -k https://localhost:8443/secure/data
 */
[
  {
    "server": {
      "serverId": "api-server",
      "port": 9001,
      "globalHeaders": [{"name": "Content-Type", "value": "application/json"}]
    },
    "expectations": [
      {
        "httpRequest": {"method": "GET", "path": "/api/users"},
        "httpResponse": {"statusCode": 200, "body": `{"users": [{"id": 1, "name": "John"}]}`}
      },
      {
        "httpRequest": {"method": "POST", "path": "/api/users"},
        "httpResponse": {"statusCode": 201, "body": `{"id": 2, "message": "Created"}`}
      }
    ]
  },
  {
    "server": {
      "serverId": "secure-server",
      "port": 8443,
      "tlsConfig": {"certificate": "/path/to/cert.pem", "privateKey": "/path/to/key.pem"}
    },
    "expectations": [
      {
        "httpRequest": {"method": "GET", "path": "/secure/data"},
        "httpResponse": {"statusCode": 200, "body": `{"data": "secure content"}`}
      }
    ]
  }
]
